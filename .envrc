# Auto-load the dev environment on `cd` via direnv.
#
# Linux: load the nix-shell defined in shell.nix (replicates the mise env).
# macOS: do nothing — mise (.mise.toml) handles activation there.
#
# This file is OS-guarded so it can safely sync between both machines.
if [ "$(uname -s)" = "Linux" ]; then
  use nix
fi
